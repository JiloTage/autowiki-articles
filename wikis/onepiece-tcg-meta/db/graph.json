{
  "nodes": [
    {
      "id": "throne-stage-lord",
      "title": "トローン卿",
      "url": "articles/throne-stage-lord.html",
      "summary": "ワンピースカードゲームにおける最強クラスのステージカード。赤青エース（白髭）デッキの核として猛威を振るい、現行メタゲームを大きく塗り替えたキーカード。",
      "is_root": false
    },
    {
      "id": "red-blue-ace-deck",
      "title": "赤青エース（白髭）デッキ",
      "url": "articles/red-blue-ace-deck.html",
      "summary": "赤青エース（白髭）デッキは、赤（炎属性）と青（海軍・技術属性）の2色を組み合わせた中速コントロール型の構築であり、トローン卿とエースのシナジーを軸に現行メタゲームのトップティアに君臨する。",
      "is_root": false
    },
    {
      "id": "ace-portgas-card",
      "title": "ポートガス・D・エース",
      "url": "articles/ace-portgas-card.html",
      "summary": "ワンピースカードゲームにおける最重要アタッカーカード。トローン卿との強力なシナジーによって赤青エース（白髭）デッキの核を担い、炎の悪魔の実に由来する特殊効果で競技環境を席巻する。",
      "is_root": false
    },
    {
      "id": "current-meta-overview",
      "title": "現行メタゲーム概要",
      "url": "articles/current-meta-overview.html",
      "summary": "ワンピースカードゲームの現行メタゲームを解説。Tier構造・主要デッキ・サイクルダイナミクスから大会シーンまで、競技環境の全体像を体系的にまとめる。",
      "is_root": false
    },
    {
      "id": "whitebeard-edward-newgate",
      "title": "白髭（エドワード・ニューゲート）",
      "url": "articles/whitebeard-edward-newgate.html",
      "summary": "ワンピースカードゲームにおける圧倒的なパワーとユニークな効果を持つ最高レアリティのキャラクターカード。赤青エースデッキのフィニッシャーとして競技環境の頂点に君臨する。",
      "is_root": false
    },
    {
      "id": "control-deck-meta",
      "title": "コントロールデッキのメタ",
      "url": "articles/control-deck-meta.html",
      "summary": "ワンピースカードゲームにおけるコントロールデッキのメタゲーム上の位置づけを解説。主要デッキ一覧・対アグロ戦略・ミラーマッチ・トローン卿採用構築の強みを体系的にまとめる。",
      "is_root": false
    },
    {
      "id": "ban-restriction-policy",
      "title": "制限・禁止カード議論",
      "url": "articles/ban-restriction-policy.html",
      "summary": "ワンピースカードゲームにおける制限・禁止カード制度の概要と歴史を解説し、特にトローン卿をはじめとする規制議論の賛否両論・メタゲームへの影響を体系的にまとめる。",
      "is_root": false
    },
    {
      "id": "stage-removal-counter",
      "title": "ステージ対策カード",
      "url": "articles/stage-removal-counter.html",
      "summary": "ステージカードへの有効な対策手段を体系的に解説する記事。各色が持つ除去・無効化手段の特徴と、競技環境における採用実態を網羅する。",
      "is_root": false
    },
    {
      "id": "aggro-deck-meta",
      "title": "アグロデッキのメタ",
      "url": "articles/aggro-deck-meta.html",
      "summary": "ワンピースカードゲームにおけるアグロデッキのメタゲーム上の位置づけを解説。序盤の爆発力でライフを削りきる戦略と、コントロール・ミッドレンジへの対応方法を体系的にまとめる。",
      "is_root": false
    },
    {
      "id": "tournament-cs-format",
      "title": "CS・大会フォーマット",
      "url": "articles/tournament-cs-format.html",
      "summary": "ワンピースカードゲームにおけるCS（カードショップ主催大会）および公式大会フォーマットを解説。参加資格・デッキ登録ルール・大会形式から競技シーンで採用される主要デッキ傾向まで体系的にまとめる。",
      "is_root": false
    },
    {
      "id": "card-color-system",
      "title": "カードカラーシステム",
      "url": "articles/card-color-system.html",
      "summary": "ワンピースカードゲームにおける6色のカードカラーシステムを解説する。各色は独自の戦略的アイデンティティを持ち、デッキ構築の根幹を形成する。",
      "is_root": false
    },
    {
      "id": "leader-card-strategy",
      "title": "リーダーカード戦略",
      "url": "articles/leader-card-strategy.html",
      "summary": "ワンピースカードゲームにおけるリーダーカード戦略の基礎から応用まで、デッキ構築の核となるリーダー選択の理論と実践を解説する。",
      "is_root": false
    },
    {
      "id": "whitebeard-pirate-crew",
      "title": "白髭海賊団カード群",
      "url": "articles/whitebeard-pirate-crew.html",
      "summary": "ワンピースカードゲームにおける白髭海賊団関連カード群の総合解説。マルコ・エースをはじめとする主力幹部カードから船員サポート群まで、トローン卿・白髭とのシナジーネットワークを詳しく掘り下げる。",
      "is_root": false
    },
    {
      "id": "don-cost-management",
      "title": "ドンコスト管理の基礎",
      "url": "articles/don-cost-management.html",
      "summary": "ワンピースカードゲームにおけるドンカードの基本ルールと運用理論を解説する。ドンコスト管理は勝敗を左右する最重要スキルであり、精密なリソース計算が求められる。",
      "is_root": false
    }
  ],
