{
  "nodes": [
    {
      "id": "claude-code-overview",
      "title": "Claude Code 概要",
      "url": "articles/claude-code-overview.html",
      "summary": "Claude Code は Anthropic が開発したAIコーディングアシスタントのCLIツールであり、TypeScriptで実装された約51万行のコードベースを持つ。エージェント型アーキテクチャを採用し、ファイル操作・シェル実行・Web検索など多様なツールをAIが自律的に活用できる設計になっている。",
      "is_root": false
    },
    {
      "id": "agent-architecture",
      "title": "エージェントアーキテクチャ",
      "url": "articles/agent-architecture.html",
      "summary": "Claude Code のエージェントシステムは AgentTool を中心に構成されており、サブエージェントの生成・実行・管理を行う。ビルトイン・カスタム・プラグインの3カテゴリのエージェントをサポートし、MCP サーバー依存フィルタリング・パーミッションスコーピング・コンテキスト分離などの高度な機能を持つ。",
      "is_root": false
    },
    {
      "id": "tool-system",
      "title": "ツールシステム",
      "url": "articles/tool-system.html",
      "summary": "Claude Code のツールシステムは Tool インターフェースを基盤とし、29の常時利用可能なコアツールと条件付きツールで構成される。各ツールは独立したディレクトリ構造を持ち、実装・UI・プロンプト・セキュリティ検証が分離されている。",
      "is_root": false
    },
    {
      "id": "query-engine",
      "title": "QueryEngine",
      "url": "articles/query-engine.html",
      "summary": "QueryEngine（src/QueryEngine.ts、46.6 KB）は Claude Code の会話ライフサイクルを管理するコアコンポーネントである。可変メッセージ状態の維持・パーミッション拒否のトラッキング・API 使用量の管理・セッションのトランスクリプトストレージへの永続化を担当する。",
      "is_root": false
    },
    {
      "id": "query-loop",
      "title": "クエリループ",
      "url": "articles/query-loop.html",
      "summary": "クエリループ（src/query.ts、68.7 KB）はマルチターンの LLM 処理を実装する非同期ジェネレータである。セットアップ・コンテキスト準備・モデル呼び出し・エラーリカバリー・ツール実行・継続の6フェーズで構成され、プロンプトが長すぎる場合や最大出力トークン数に達した場合のリカバリーメカニズムを備える。",
      "is_root": false
    },
    {
      "id": "prompt-engineering",
      "title": "プロンプト設計",
      "url": "articles/prompt-engineering.html",
      "summary": "Claude Code の各ツールは prompt.ts ファイルに詳細な使用指示を格納しており、AI の行動を精密に制御する。BashTool・FileEditTool・GrepTool・AgentTool・コーディネータモードなど各コンポーネントに固有のプロンプト設計パターンがある。",
      "is_root": false
    },
    {
      "id": "mcp-integration",
      "title": "MCP インテグレーション",
      "url": "articles/mcp-integration.html",
      "summary": "Claude Code は Model Context Protocol（MCP）を完全実装しており、src/services/mcp/ ディレクトリ配下に22ファイルで構成される。MCP クライアント（119 KB）・設定管理（51 KB）・OAuth 認証（88 KB）・接続管理・チャネルセキュリティ・公式レジストリ・VS Code SDK 統合が含まれる。",
      "is_root": false
    },
    {
      "id": "session-memory",
      "title": "セッションメモリ",
      "url": "articles/session-memory.html",
      "summary": "Claude Code のセッションメモリシステム（src/services/SessionMemory/）は10セクション構造のテンプレートを用いた永続的メモリ管理を提供する。セクションごとに約2000トークンの制限があり、並行 Edit ツール呼び出しで更新される。",
      "is_root": false
    },
    {
      "id": "coordinator-mode",
      "title": "コーディネータモード",
      "url": "articles/coordinator-mode.html",
      "summary": "コーディネータモード（src/coordinator/coordinatorMode.ts）はマルチエージェント並列処理を管理する Claude Code の高度な機能である。「並列性はスーパーパワー」という設計哲学のもと、独立したワーカーエージェントを並行起動して複雑なタスクを分散処理する。",
      "is_root": false
    },
    {
      "id": "bridge-system",
      "title": "ブリッジシステム",
      "url": "articles/bridge-system.html",
      "summary": "ブリッジシステム（src/bridge/、33ファイル）は Claude Code CLI と IDE 拡張機能（VS Code、JetBrains）間の双方向通信を実現する。JWT 認証によるメッセージセキュリティ・セッションライフサイクル管理・デバイス信頼管理などを実装する。",
      "is_root": false
    },
    {
      "id": "context-compaction",
      "title": "コンテキスト圧縮",
      "url": "articles/context-compaction.html",
      "summary": "Claude Code のコンテキスト圧縮システム（src/services/compact/、11ファイル）はトークン制限への対応機構である。コアコンパクション（60 KB）・自動コンパクション・マイクロコンパクション・セッションメモリ対応コンパクション・圧縮プロンプトの5コンポーネントで構成される。",
      "is_root": false
    },
    {
      "id": "claude-code-architecture",
      "title": "リポジトリ構造",
      "url": "articles/claude-code-architecture.html",
      "summary": "JiloTage/claude-code リポジトリは Anthropic の Claude Code CLI のソースコードアーカイブである。npm 配布パッケージの .map ファイルから抽出された約1,900の TypeScript ファイル・51万2千行超のコードで構成される。",
      "is_root": false
    }
  ],
