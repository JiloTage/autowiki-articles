{
  "nodes": [
    {
      "id": "hokuo-shinwa-yukari-machi:hokuo-shinwa-no-machi",
      "wiki": "hokuo-shinwa-yukari-machi",
      "title": "北欧神話にゆかりのある街",
      "url": "wikis/hokuo-shinwa-yukari-machi/articles/hokuo-shinwa-no-machi.html",
      "color": "#4a6fa5",
      "is_root": false,
      "summary": "北欧神話にゆかりのある街とは、スカンジナビアを中心に、ヴァイキング時代の宗教・文化・伝説と深く結びついた実在の都市・集落、および神話的世界観の中に語られる都市を指す。ウプサラ、トロンヘイム、ロスキレ、ヨーク、レイキャビクなど各都市の特徴を概観する。"
    },
    {
      "id": "hokuo-shinwa-yukari-machi:gamla-uppsala",
      "wiki": "hokuo-shinwa-yukari-machi",
      "title": "ガムラ・ウプサラ（古いウプサラ）",
      "url": "wikis/hokuo-shinwa-yukari-machi/articles/gamla-uppsala.html",
      "color": "#4a6fa5",
      "is_root": false,
      "summary": "ガムラ・ウプサラ（古いウプサラ）は、スウェーデン・ウプサラ市北部に位置する古代の聖地・王権の中心地。ヴァイキング時代の三大神殿（オーディン・トール・フレイ）、9年ごとの人身御供儀式、6〜7世紀の王墓群（インギャルド墳）、発掘遺物、現代の考古学公園について詳述する。"
    },
    {
      "id": "hokuo-shinwa-yukari-machi:roskilde",
      "wiki": "hokuo-shinwa-yukari-machi",
      "title": "ロスキレ",
      "url": "wikis/hokuo-shinwa-yukari-machi/articles/roskilde.html",
      "color": "#4a6fa5",
      "is_root": false,
      "summary": "ロスキレはデンマーク・ジェラン島に位置する古都。10〜11世紀のデンマーク王国の首都として栄え、ヴァイキング船博物館とユネスコ世界遺産のロスキレ大聖堂を擁する北欧神話・ヴァイキング文化の一大拠点である。"
    },
    {
      "id": "hokuo-shinwa-yukari-machi:uppsala",
      "wiki": "hokuo-shinwa-yukari-machi",
      "title": "ウプサラ",
      "url": "wikis/hokuo-shinwa-yukari-machi/articles/uppsala.html",
      "color": "#4a6fa5",
      "is_root": false,
      "summary": "ウプサラはスウェーデン中部に位置する歴史都市で、北欧最大の異教徒聖地であった「ガムラ・ウプサラ」を擁し、北欧神話・ヴァイキング時代の宗教文化における最重要拠点の一つである。"
    },
    {
      "id": "hokuo-shinwa-yukari-machi:trondheim",
      "wiki": "hokuo-shinwa-yukari-machi",
      "title": "トロンヘイム（ニーダロス）",
      "url": "wikis/hokuo-shinwa-yukari-machi/articles/trondheim.html",
      "color": "#4a6fa5",
      "is_root": false,
      "summary": "トロンヘイム（古名：ニーダロス）はノルウェー中西部に位置する歴史的都市。ヴァイキング時代にはノルウェー王国の政治・宗教の中心地として栄え、聖オーラフによるキリスト教化の拠点となった。ニーダロス大聖堂はスカンジナビア最大のゴシック建築として知られ、ヴァイキング文化から中世キリスト教へ移行する象徴的存在である。"
    },
    {
      "id": "hokuo-shinwa-yukari-machi:oslo",
      "wiki": "hokuo-shinwa-yukari-machi",
      "title": "オスロ",
      "url": "wikis/hokuo-shinwa-yukari-machi/articles/oslo.html",
      "color": "#4a6fa5",
      "is_root": false,
      "summary": "オスロはノルウェーの首都かつ最大都市。ヴァイキング船博物館・ヴィーゲラン公園・カウパング交易地との歴史的つながりなど、北欧神話とヴァイキング文化の遺産を今日に伝える重要な都市である。"
    },
    {
      "id": "hokuo-shinwa-yukari-machi:york-jorvík",
      "wiki": "hokuo-shinwa-yukari-machi",
      "title": "ヨーク（ヨールヴィーク）",
      "url": "wikis/hokuo-shinwa-yukari-machi/articles/york-jorvík.html",
      "color": "#4a6fa5",
      "is_root": false,
      "summary": "ヨーク（古ノルド語：ヨールヴィーク）はイングランド北部に位置する歴史都市で、866年のデーン人による征服から954年まで続いたヴァイキング王国「ヨールヴィーク王国」の首都として栄えた。豊富な考古学的遺物と現代のヨールヴィーク・ヴァイキング・センターにより、北欧神話とヴァイキング文化を体感できる世界的な観光地となっている。"
    },
    {
      "id": "hokuo-shinwa-yukari-machi:reykjavik",
      "wiki": "hokuo-shinwa-yukari-machi",
      "title": "レイキャビク",
      "url": "wikis/hokuo-shinwa-yukari-machi/articles/reykjavik.html",
      "color": "#4a6fa5",
      "is_root": false,
      "summary": "レイキャビクはアイスランドの首都であり、874年のヴァイキングによる入植以来、北欧神話の主要文書であるエッダ・サガの成立地として知られる。世界最古の議会アルシング（930年）の開催地シングヴェトリルを近郊に擁し、北欧神話の伝承と保存において世界で最も重要な都市のひとつである。"
    },
    {
      "id": "claude-code-skills-sharing:skills-sharing-overview",
      "wiki": "claude-code-skills-sharing",
      "title": "Claude Code Skills共有方法 概要",
      "url": "wikis/claude-code-skills-sharing/articles/skills-sharing-overview.html",
      "color": "#2e7d32",
      "is_root": false,
      "summary": "Claude Code用のSkillsをプライベートリポジトリで社内に広く共有するための方法を体系的に解説する。npm/GitHubパッケージ、Gitサブモジュール、モノレポ構成など複数のアプローチを比較検討する。"
    },
    {
      "id": "claude-code-skills-sharing:npm-github-packages",
      "wiki": "claude-code-skills-sharing",
      "title": "npm / GitHub Packagesによるプライベートスキル配布",
      "url": "wikis/claude-code-skills-sharing/articles/npm-github-packages.html",
      "color": "#2e7d32",
      "is_root": false,
      "summary": "GitHub Packagesのプライベートnpmレジストリを活用してClaude Code Skillsを社内に配布する方法。セマンティックバージョニングによる厳密なバージョン管理と、package.jsonによる依存関係の記録が可能。"
    },
    {
      "id": "claude-code-skills-sharing:git-submodule-approach",
      "wiki": "claude-code-skills-sharing",
      "title": "Gitサブモジュールを使ったスキル共有アプローチ",
      "url": "wikis/claude-code-skills-sharing/articles/git-submodule-approach.html",
      "color": "#2e7d32",
      "is_root": false,
      "summary": "Gitのサブモジュール機能を活用して、Claude Code Skillsを専用リポジトリからプロジェクトに組み込む方法。追加ツール不要でGit標準機能のみを使う、バランスの良いアプローチ。"
    },
    {
      "id": "claude-code-skills-sharing:monorepo-skills",
      "wiki": "claude-code-skills-sharing",
      "title": "モノレポ構成でのClaude Code Skills管理",
      "url": "wikis/claude-code-skills-sharing/articles/monorepo-skills.html",
      "color": "#2e7d32",
      "is_root": false,
      "summary": "すべてのプロジェクトを単一リポジトリで管理するモノレポ構成において、Claude Code Skillsを一元管理する方法。高い可視性と即時反映が可能。"
    },
    {
      "id": "claude-code-skills-sharing:central-repo-approach",
      "wiki": "claude-code-skills-sharing",
      "title": "セントラルリポジトリからのスキル配布",
      "url": "wikis/claude-code-skills-sharing/articles/central-repo-approach.html",
      "color": "#2e7d32",
      "is_root": false,
      "summary": "最もシンプルなClaude Code Skills共有方法。Skillsを集約した専用プライベートリポジトリを作成し、各開発者がクローンして手動またはスクリプトでセットアップする。追加ツール不要で即日導入できる。"
    },
    {
      "id": "claude-code-skills-sharing:setup-automation",
      "wiki": "claude-code-skills-sharing",
      "title": "スキル配布のセットアップ自動化スクリプト",
      "url": "wikis/claude-code-skills-sharing/articles/setup-automation.html",
      "color": "#2e7d32",
      "is_root": false,
      "summary": "Claude Code Skillsの配布・インストール・更新を自動化するスクリプトパターン集。開発者のオンボーディングを「ワンコマンド」に集約し、配布方法に依らず適用できる。"
    }
  ],
